    "settings:apply": "node --env-file=.env scripts/apply-settings.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "autoprefixer": "^10.4.24",
    "class-variance-authority": "^0.7.1",
